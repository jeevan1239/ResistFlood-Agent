{
  "name": "resistflood",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:accessibility": "playwright test tests/e2e/accessibility.spec.js",
    "test:visual": "playwright test tests/e2e/visual.spec.js",
    "test:coverage": "vitest run --coverage",
    "test:all": "npm run test && npm run test:e2e",
    "demo:seed": "node server/scripts/seedDemo.js",
    "db:reset": "node server/scripts/resetDB.js"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.49.1",
    "@vitest/coverage-v8": "^2.1.8",
    "mongodb-memory-server": "^10.1.2",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@google/genai": "^1.0.0",
    "@turf/turf": "^7.3.5",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.5",
    "multer": "^2.2.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  }
}
