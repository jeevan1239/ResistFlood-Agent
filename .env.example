# ==============================================================================
# ResistFlood — Root Environment Variables
# ==============================================================================
# Copy this file and fill in your values:
#   cp .env.example .env
#
# The ONLY variable you MUST fill in to run the app is GEMINI_API_KEY.
# Everything else works out-of-the-box with docker compose up --build.
#
# Get your Gemini API key (free, no credit card):
#   https://aistudio.google.com/ → "Get API key"
# ==============================================================================


# ── Gemini AI ─────────────────────────────────────────────────────────────────
# REQUIRED. Get yours free at https://aistudio.google.com/ → "Get API key".
# Do NOT enable billing on the Google Cloud project — it removes the free tier.
GEMINI_API_KEY=


# ── MongoDB ───────────────────────────────────────────────────────────────────
# docker-compose.yml automatically overrides this with the local MongoDB
# container (mongodb://mongodb:27017/resistflood) so you do not need to change
# this for local Docker development.
#
# To connect to MongoDB Atlas instead, replace with your Atlas connection string
# and remove or comment out the MONGODB_URI line in docker-compose.yml.
MONGODB_URI=mongodb://mongodb:27017/resistflood


# ── Authentication ────────────────────────────────────────────────────────────
# Any long random string. Generate one with:  openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-secret


# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000

# URL of the React client — used by Express for CORS.
# Keep as-is for local Docker development.
CLIENT_URL=http://localhost:5173


# ── Image Uploads ─────────────────────────────────────────────────────────────
# Images are stored locally inside Docker (server/uploads/).
# The docker-compose named volume (uploads_data) makes them persist across
# container restarts. No Cloudinary account is needed for local development.
#
# If you want to use Cloudinary in production, fill these in and update

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=


# ── Push Notifications (optional) ────────────────────────────────────────────
# Push notifications are optional for local development.
# Generate VAPID keys with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
